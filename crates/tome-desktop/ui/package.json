{
  "name": "tome-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "tome desktop frontend (React, chosen in Phase 25 spike 25-06). Co-located with the canonical generated src/bindings.ts (the single TS source of truth, regenerated by `cargo run -p tome-desktop --bin gen-bindings`).",
  "scripts": {
    "dev": "vite",
    "dev:a11y": "A11Y_TEST=1 vite --port 1420 --strictPort",
    "dev:perf": "PERF_TEST=1 vite --port 1420 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "playwright test --config=../tests/a11y/playwright.config.ts",
    "test:perf": "playwright test --config=../tests/perf/playwright.config.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "fuse.js": "^7.3.0",
    "react": "^19.1.0",
    "react-aria-components": "^1.18.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "playwright": "^1.60.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.7"
  }
}
