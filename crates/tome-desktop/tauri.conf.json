{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tome",
  "version": "0.16.0",
  "identifier": "com.martinp7r.tome",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "cwd": "ui",
      "script": "npm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "ui",
      "script": "npm run build"
    }
  },
  "app": {
    "windows": [
      {
        "title": "tome",
        "width": 1100,
        "height": 740,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/icon.png"
    ]
  }
}
