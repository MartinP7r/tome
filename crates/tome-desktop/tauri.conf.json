{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tome",
  "version": "0.16.0",
  "identifier": "com.martinp7r.tome",
  "build": {
    "frontendDist": "ui-svelte/dist",
    "devUrl": "http://localhost:1422",
    "beforeDevCommand": {
      "cwd": "ui-svelte",
      "script": "npm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "ui-svelte",
      "script": "npm run build"
    }
  },
  "app": {
    "windows": [
      {
        "title": "tome",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/icon.png"
    ]
  }
}
